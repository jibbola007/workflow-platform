{
  "name": "workflow-platform",
  "private": true,
  "packageManager": "npm@10.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run db:generate -w @workflow/database",
    "db:migrate": "npm run db:migrate -w @workflow/database"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
